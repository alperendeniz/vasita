# .env.example — Ortam değişkenleri şablonu
# Bu dosyayı kopyalayıp .env olarak kaydet ve değerleri doldur.
# ASLA gerçek .env dosyasını Git'e gönderme!

FLASK_APP=run.py
FLASK_ENV=development

# En az 24 karakterlik rastgele bir dize kullan
SECRET_KEY=gizli-bir-anahtar-buraya-gir

# SQLite (yerel) ya da PostgreSQL bağlantı URL'si
DATABASE_URL=sqlite:///instance/vasita.db
